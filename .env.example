# AddressIQ Web SDK — local development overrides.
#
#   cp .env.example .env      # .env is gitignored; put real values there
#   npm run build             # rollup reads .env automatically
#
# Real environment variables always win over .env, so CI — which sets the
# STAGING_*/PROD_* repository variables directly, and has no .env file — is
# unaffected by anything here.
#
# EVERY value here is DEVELOPMENT-ONLY. They feed the `development` deployment,
# and `googleMapsApiKey` is rejected outright on a staging or production build.

# ── Development hosts ────────────────────────────────────────────────────────
# Default to http://localhost:4000. Override to point at a LAN IP, a colleague's
# backend, or a tunnel.
#
# NOTE the DEV_ prefix. The UNPREFIXED `ADDRESSIQ_API_URL` is the legacy name for
# the PRODUCTION api host (rollup.config.mjs) — setting *that* one and running a
# build would bake your local host in as production, and it is a valid URL, so
# scripts/check-baked-config.mjs would not catch it. Never use the unprefixed name
# for local work.
ADDRESSIQ_DEV_API_URL=http://localhost:4000
ADDRESSIQ_DEV_INGEST_URL=http://localhost:4000
ADDRESSIQ_DEV_CDN_URL=http://localhost:4000

# ── Google Maps key ──────────────────────────────────────────────────────────
# Baked into the bundle as the last-resort fallback. The widget prefers the key
# the backend returns from GET /api/v1/widget/config, so keys can rotate without
# a rebuild. Leave empty for local work unless you are exercising the map.
#
# (This is the same variable CI supplies at release; it is not a dev-only name.)
GOOGLE_MAPS_SDK_KEY=
